# Database — used by TimescaleDB container and all services that connect to it
DB_USER=exchange_user
DB_PASSWORD=change_me_to_something_strong
DB_NAME=exchange_db
DB_PORT=5432

# Frontend URLs — replace with your server's public IP or domain
# Use ws:// (or wss:// if you set up SSL)
NEXT_PUBLIC_API_URL=http://YOUR_SERVER_IP/api/v1
NEXT_PUBLIC_WS_URL=ws://YOUR_SERVER_IP/ws
